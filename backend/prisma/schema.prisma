generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  password  String
  role      String   // "ADMIN" | "MOTOBOY"
  status    String   @default("OFFLINE") // "ONLINE" | "OFFLINE"
  salary    Float?   @default(0.0)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id              Int       @id @default(autoincrement())
  customerName    String
  address         String
  phone           String
  status          String    @default("PENDING") // PENDING, ACCEPTED, IN_TRANSIT, DELIVERED
  orderValue      Float     @default(0.0)
  deliveryFee     Float     @default(0.0)
  motoboyPaid     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  deliveredAt     DateTime?
  motoboyId       Int?
  motoboy         User?     @relation(fields: [motoboyId], references: [id])
}

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
