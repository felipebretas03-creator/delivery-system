generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   // "ADMIN" | "MOTOBOY"
  status    String   @default("OFFLINE") // "ONLINE" | "OFFLINE"
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id              Int       @id @default(autoincrement())
  customerName    String
  address         String
  phone           String
  status          String    @default("PENDING") // PENDING, ACCEPTED, IN_TRANSIT, DELIVERED
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  deliveredAt     DateTime?
  motoboyId       Int?
  motoboy         User?     @relation(fields: [motoboyId], references: [id])
}
